# sower API configuration (validated in apps/api/src/config.ts)
# Copy to .env and fill in real values. NEVER commit .env.

# Port the API listens on.
PORT=8080

# Postgres connection string (postgres-js format).
DATABASE_URL=postgres://sower:sower@localhost:5432/sower

# Shared secret required in the x-api-key header for all mutating routes.
INGEST_API_KEY=change-me-long-random-string

# Queue driver: 'inline' (process in-request, local dev) or 'cloud-tasks' (GCP).
QUEUE_DRIVER=inline

# --- Cloud Tasks (only required when QUEUE_DRIVER=cloud-tasks) ---
# GCP project id, e.g. sower-production.
GCP_PROJECT_ID=
# GCP region, e.g. us-east1.
GCP_REGION=
# Cloud Tasks queue name.
TASKS_QUEUE=apply-queue
# Base URL Cloud Tasks calls back into (the deployed API), e.g. https://sower-api-xxxx.run.app
TASKS_TARGET_BASE_URL=

# Path to the applicant profile YAML (sample profile is fake data only).
PROFILE_PATH=./config/profile.sample.yaml

# --- Simplify source ---
# Comma-separated search terms.
SIMPLIFY_TERMS=Summer 2027
# Max jobs ingested per source run.
SIMPLIFY_MAX_PER_RUN=10

# HARD GUARDRAIL: submissions are dry-run only. Even 'true' never submits a
# real application; it only logs the dry-run payload.
SOWER_SUBMIT_ENABLED=false

# 'development' | 'production'
SOWER_ENV=development
