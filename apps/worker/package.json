{
  "name": "@sower/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "start": "tsx src/main.ts",
    "agent": "tsx scripts/agent.ts",
    "recon": "tsx scripts/workday-recon.ts",
    "fill": "tsx scripts/workday-fill.ts",
    "capture-session": "tsx scripts/workday-session-capture.ts",
