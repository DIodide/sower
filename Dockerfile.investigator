# Cloud Run Job image for @sower/investigator (Tier-2 screenshot investigation).
# NOTE: do NOT prune optional dependencies — @anthropic-ai/claude-agent-sdk
# ships its Claude Code binary via platform-specific optional deps; removing
# them breaks the SDK at runtime.
FROM node:22-slim

ENV COREPACK_ENABLE_DOWNLOAD_PROMPT=0
RUN corepack enable

WORKDIR /app
COPY . .

RUN corepack pnpm install --frozen-lockfile --filter @sower/investigator...

# The Claude Code subprocess needs a writable HOME and config dir.
ENV HOME=/home/node
ENV CLAUDE_CONFIG_DIR=/tmp/.claude
RUN mkdir -p /home/node /tmp/.claude && chmod -R 0777 /home/node /tmp/.claude

CMD ["corepack", "pnpm", "--filter", "@sower/investigator", "start"]
