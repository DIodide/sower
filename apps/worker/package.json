    "@sower/platforms": "workspace:*",
    "@sower/storage": "workspace:*",
    "drizzle-orm": "^0.44.0",
    "playwright": "^1.49.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.20.3",
    "typescript": "^7.0.2",
    "vitest": "^3.2.4"
  }
