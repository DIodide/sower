# Sower API environment variables (placeholders only — never commit real values)

# Port the Fastify server listens on
PORT=8080

# Postgres connection string (required)
DATABASE_URL=postgres://postgres:sower@localhost:5432/sower

# Shared secret required in the x-api-key header on all mutating routes (required)
INGEST_API_KEY=change-me

# Queue driver: 'inline' processes tasks in-process, 'cloud-tasks' uses GCP Cloud Tasks
QUEUE_DRIVER=inline

# GCP settings (only needed when QUEUE_DRIVER=cloud-tasks)
# GCP_PROJECT_ID=sower-production
# GCP_REGION=us-east1
# TASKS_QUEUE=apply-queue
# TASKS_TARGET_BASE_URL=https://api.example.com

# Path to the applicant profile YAML (sample profile is fake data only)
PROFILE_PATH=./config/profile.sample.yaml

# Simplify source polling
SIMPLIFY_TERMS=Summer 2027
SIMPLIFY_MAX_PER_RUN=10

# Discord approval cards + interactions.
# DISCORD_BOT_TOKEN is a SECRET (Secret Manager in production) — never commit
# a real value. Leave it unset to disable Discord features entirely.
# DISCORD_BOT_TOKEN=
# The remaining Discord values are NON-secrets with committed defaults; set
# them only to override.
# DISCORD_PUBLIC_KEY=c461bfe425fa9fb69b7ae93f440e957ab93b472be6525502a7374b0f01813f5c
# DISCORD_APP_ID=1525747560684322956
# DISCORD_CHANNEL_MAP={"greenhouse":"1525749024261541978","ashby":"1525749024827641877","lever":"1525749025897316503","workday":"1525749026451095595"}
# DISCORD_FALLBACK_CHANNEL=

# Safety: submissions are hard-disabled unless this is exactly 'true'
SOWER_SUBMIT_ENABLED=false

# Environment name reported by /healthz
SOWER_ENV=development
